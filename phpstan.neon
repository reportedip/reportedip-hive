includes:
    # WordPress stubs for proper type recognition
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    # Level 5 + treatPhpDocTypesAsCertain — strictest setting that still
    # works against WordPress core's mixed-typed return signatures (`get_option`,
    # `$wpdb->get_results`, …). Levels 6+ require unionising every core call
    # site which is a 50+ file refactor without a security payoff. We DO honour
    # PHPDoc types as certain so a wrong @param type is now an error, not a
    # hint.
    level: 5

    # Result cache directory: outside the plugin folder so Plugin Check / WP-CLI
    # do not flag the cache files as production code. CI caches this path via
    # actions/cache (key on composer.lock + phpstan.neon).
    tmpDir: ../.phpstan-cache

    # Paths to analyse
    paths:
        - reportedip-hive.php
        - includes/
        - admin/
        - templates/

    # Paths to exclude. The `(?)` suffix marks the path as optional — required
    # by PHPStan 2.x for directories that may not exist locally (node_modules/
    # and bin/ are CI-time-only; scripts/ contains dev-only diagnostic tools).
    excludePaths:
        - vendor/
        - node_modules/ (?)
        - tests/
        - bin/ (?)
        - scripts/ (?)

    # Scan also files not listed in paths (for dependencies)
    scanFiles:
        - reportedip-hive.php

    # Bootstrap defines plugin constants for static analysis. Lives under tests/
    # which is excluded from the production ZIP and from WordPress.org Plugin
    # Check, so it never reaches end users.
    bootstrapFiles:
        - tests/phpstan-bootstrap.php

    # Ignore missing array typehints (common in WordPress)
    # checkMissingIterableValueType is deprecated, use ignoreErrors instead

    # Allow dynamic properties (used extensively in WordPress)
    checkDynamicProperties: false

    # Treat phpDoc types as native types. Off because plugin code talks to
    # third-party hooks/filters whose `@return` shape we cannot enforce —
    # turning this on flags every defensive `instanceof WP_Error` /
    # `method_exists()` guard that the test suite specifically asserts must
    # remain in place to be safe against unexpected upstream returns.
    treatPhpDocTypesAsCertain: false

    # Ignore errors patterns (use sparingly!)
    ignoreErrors:
        # WordPress global $wpdb is always available
        - '#Variable \$wpdb might not be defined#'

        # Allow array access on mixed types (common in WP)
        - '#Cannot access offset .+ on mixed#'

        # Common WordPress patterns with dynamic function calls
        - '#Parameter \#1 .+ of function call_user_func#'

        # Ignore missing array type hints (deprecated option replacement)
        - identifier: missingType.iterableValue

    # Report unmatched ignored errors (keeps ignoreErrors list clean)
    reportUnmatchedIgnoredErrors: false
