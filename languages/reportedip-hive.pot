#: admin/class-admin-settings.php:4785
msgid "Counter window for XML-RPC requests."
msgstr ""

#: admin/class-admin-settings.php:4793
msgid "Application password abuse"
msgstr ""

#: admin/class-admin-settings.php:4795
msgid "Application passwords authenticate over REST and XML-RPC and skip the normal login 2FA prompt. We rate-limit failed app-password sign-ins and can optionally block new app passwords for 2FA-enforced roles until enrolment is finished."
msgstr ""

#: admin/class-admin-settings.php:4801
msgid "Watch application-password authentications"
msgstr ""

#: admin/class-admin-settings.php:4808
msgid "Block app-password creation until 2FA enrolment is finished (for enforced roles)"
msgstr ""

#: admin/class-admin-settings.php:4814
msgid "How many failed auths?"
msgstr ""

#: admin/class-admin-settings.php:4827
msgid "REST API abuse"
msgstr ""

#: admin/class-admin-settings.php:4829
msgid "Per-IP rate limit on /wp-json/* requests. Catches scrapers and vulnerability scanners that hammer the REST surface. Sensitive routes (/wp/v2/users, /wp/v2/comments) use a tighter threshold by default."
msgstr ""

#: admin/class-admin-settings.php:4835
msgid "Watch REST API requests"
msgstr ""

#: admin/class-admin-settings.php:4841
msgid "Global requests threshold"
msgstr ""

#: admin/class-admin-settings.php:4849
