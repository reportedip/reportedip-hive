msgstr ""

#: admin/class-admin-settings.php:4722
msgid "How many distinct usernames?"
msgstr ""

#: admin/class-admin-settings.php:4735
#: admin/class-admin-settings.php:7330
msgid "Comment spam"
msgstr ""

#: admin/class-admin-settings.php:4737
msgid "When the same IP submits comments that WordPress flags as spam in rapid succession, treat that IP as a threat."
msgstr ""

#: admin/class-admin-settings.php:4743
msgid "Watch comment spam"
msgstr ""

#: admin/class-admin-settings.php:4749
msgid "How many spam comments?"
