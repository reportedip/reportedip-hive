#, php-format
msgid "Welcome to Two-Factor Authentication for %s"
msgstr "Willkommen zur Zwei-Faktor-Authentifizierung (2FA) für %s"

#: templates/two-factor-onboarding.php:156
msgid "A second factor protects your sign-in even if your password leaks. Takes about 2 minutes."
msgstr "Ein zweiter Faktor schützt Ihre Anmeldung selbst dann, wenn Ihr Passwort geleakt wird. Dauert etwa 2 Minuten."

#: templates/two-factor-onboarding.php:161
msgid "Let's start"
msgstr "Los geht's"

#: templates/two-factor-onboarding.php:168
msgid "Choose your method"
msgstr "Wählen Sie Ihre Methode"

#: templates/two-factor-onboarding.php:170
msgid "Which second factor would you like to use when you sign in?"
msgstr "Welchen zweiten Faktor möchten Sie bei der Anmeldung verwenden?"

#: templates/two-factor-onboarding.php:173
msgid "Multi-select — click one or more cards"
msgstr "Mehrfachauswahl — klicken Sie auf eine oder mehrere Karten"

#: templates/two-factor-onboarding.php:191
msgid "Passkey / biometrics"
msgstr "Passkey / Biometrie"

#: templates/two-factor-onboarding.php:193
msgid "Face ID, Touch ID, Windows Hello or hardware key. Phishing-resistant, no app needed."
msgstr "Face ID, Touch ID, Windows Hello oder Hardware-Schlüssel. Phishing-resistent, keine App nötig."

#: templates/two-factor-onboarding.php:204
msgid "Authenticator app (TOTP)"
msgstr "Authenticator-App (TOTP)"

#: templates/two-factor-onboarding.php:206
msgid "Google Authenticator, Authy, 1Password. Works offline, no SMS or email needed."
msgstr "Google Authenticator, Authy, 1Password. Funktioniert offline, ohne SMS oder E-Mail."

#. translators: %s: masked email
#: templates/two-factor-onboarding.php:222
#, php-format
msgid "We will send a 6-digit code to %s."
msgstr "Wir senden einen 6-stelligen Code an %s."

#: templates/two-factor-onboarding.php:236
msgid "SMS (worldwide)"
msgstr "SMS (weltweit)"

#: templates/two-factor-onboarding.php:238
msgid "Code by SMS via a GDPR-compliant provider. Best as a backup — SIM-swapping risk."
msgstr "Code per SMS über einen DSGVO-konformen Anbieter. Am besten als Backup — SIM-Swapping-Risiko."

#: templates/two-factor-onboarding.php:245
msgid "Add a backup method (e.g. passkey plus email) to avoid lockouts."
msgstr "Fügen Sie eine Backup-Methode hinzu (z. B. Passkey plus E-Mail), um Aussperrungen zu vermeiden."

#: templates/two-factor-onboarding.php:258
#: templates/two-factor-onboarding.php:259
msgid "Set up methods"
msgstr "Methoden einrichten"

#: templates/two-factor-onboarding.php:258
msgid "All methods active"
msgstr "Alle Methoden aktiv"

#: templates/two-factor-onboarding.php:261
#: templates/two-factor-onboarding.php:262
msgid "Verify each selected method to activate it."
msgstr "Bestätigen Sie jede ausgewählte Methode, um sie zu aktivieren."

#: templates/two-factor-onboarding.php:261
msgid "Ready for recovery codes."
msgstr "Bereit für Wiederherstellungscodes."

#: templates/two-factor-onboarding.php:269
msgid "Setup complete"
msgstr "Einrichtung abgeschlossen"

#: templates/two-factor-onboarding.php:277
msgid "Install an authenticator app on your smartphone if you don't have one yet."
msgstr "Installieren Sie eine Authenticator-App auf Ihrem Smartphone, falls Sie noch keine haben."

#: templates/two-factor-onboarding.php:284
msgid "Scan the QR code with the app (or enter the secret key manually)."
msgstr "Scannen Sie den QR-Code mit der App (oder geben Sie den geheimen Schlüssel manuell ein)."

#: templates/two-factor-onboarding.php:286
msgid "QR code to scan"
msgstr "QR-Code zum Scannen"

#: templates/two-factor-onboarding.php:288
msgid "Or enter manually:"
msgstr "Oder manuell eingeben:"

#: templates/two-factor-onboarding.php:296
msgid "Enter the 6-digit code from your app to finish setup."
msgstr "Geben Sie den 6-stelligen Code aus Ihrer App ein, um die Einrichtung abzuschließen."

#: templates/two-factor-onboarding.php:298
msgid "TOTP code"
msgstr "TOTP-Code"

#. translators: %s: email address
#: templates/two-factor-onboarding.php:313
#, php-format
msgid "We will send a confirmation code to %s."
msgstr "Wir senden einen Bestätigungscode an %s."

#: templates/two-factor-onboarding.php:321
#: templates/two-factor-onboarding.php:322
msgid "Send confirmation code to my email"
msgstr "Bestätigungscode an meine E-Mail senden"

#: templates/two-factor-onboarding.php:329
msgid "Enter the 6-digit code from the email"
msgstr "Geben Sie den 6-stelligen Code aus der E-Mail ein"

#: templates/two-factor-onboarding.php:338
msgid "Protect your email account with 2FA too."
msgstr "Schützen Sie auch Ihr E-Mail-Konto mit 2FA."

#: templates/two-factor-onboarding.php:344
msgid "Set up passkey"
msgstr "Passkey einrichten"

#: templates/two-factor-onboarding.php:346
msgid "Face ID, Touch ID, Windows Hello, YubiKey — biometric data stays on your device."
msgstr "Face ID, Touch ID, Windows Hello, YubiKey — biometrische Daten bleiben auf Ihrem Gerät."

#: templates/two-factor-onboarding.php:350
msgid "Create passkey with this device"
msgstr "Passkey mit diesem Gerät erstellen"

#: templates/two-factor-onboarding.php:353
msgid "Browser without passkey support? Pick another method."
msgstr "Browser ohne Passkey-Unterstützung? Wählen Sie eine andere Methode."

#: templates/two-factor-onboarding.php:359
msgid "Set up SMS"
msgstr "SMS einrichten"

#: templates/two-factor-onboarding.php:367
msgid "Privacy notice"
msgstr "Datenschutzhinweis"

#: templates/two-factor-onboarding.php:368
msgid "Phone number stored encrypted, delivered worldwide via our managed relay. Use SMS as a backup — SIM-swapping risk."
msgstr "Telefonnummer verschlüsselt gespeichert, weltweit zugestellt über unser verwaltetes Relay. Nutzen Sie SMS als Backup — SIM-Swapping-Risiko."

#: templates/two-factor-onboarding.php:375
msgid "Enter your mobile number"
msgstr "Geben Sie Ihre Mobilnummer ein"

#: templates/two-factor-onboarding.php:378
msgid "Mobile number (international, e.g. +49 151 12345678)"
msgstr "Mobilnummer (international, z. B. +49 151 12345678)"

#: templates/two-factor-onboarding.php:384
msgid "Format: +49 151 12345678 (country code required)."
msgstr "Format: +49 151 12345678 (Ländervorwahl erforderlich)."

#: templates/two-factor-onboarding.php:390
msgid "I consent to my phone number being shared with the EU SMS provider for authentication."
msgstr "Ich willige ein, dass meine Telefonnummer zur Authentifizierung an den EU-SMS-Anbieter weitergegeben wird."

#: templates/two-factor-onboarding.php:393
#: templates/two-factor-onboarding.php:394
msgid "Send confirmation code by SMS"
msgstr "Bestätigungscode per SMS senden"

#: templates/two-factor-onboarding.php:404
msgid "Enter the 6-digit code from the SMS"
msgstr "Geben Sie den 6-stelligen Code aus der SMS ein"

#: templates/two-factor-onboarding.php:417
msgid "Next: recovery codes"
msgstr "Weiter: Wiederherstellungscodes"

#: templates/two-factor-onboarding.php:424
msgid "Save recovery codes"
msgstr "Wiederherstellungscodes speichern"

#: templates/two-factor-onboarding.php:426
msgid "Backup codes for sign-in if you lose access to your methods."
msgstr "Backup-Codes für die Anmeldung, falls Sie den Zugriff auf Ihre Methoden verlieren."

#: templates/two-factor-onboarding.php:436
msgid "These codes are your fallback."
msgstr "Diese Codes sind Ihre Rückfallebene."

#: templates/two-factor-onboarding.php:437
msgid "Each code is one-time use. Store them safely — separate from your WordPress password."
msgstr "Jeder Code ist einmal verwendbar. Bewahren Sie sie sicher auf — getrennt von Ihrem WordPress-Passwort."

#: templates/two-factor-onboarding.php:441
msgid "Recovery codes"
msgstr "Wiederherstellungscodes"

#: templates/two-factor-onboarding.php:452
msgid "Download as .txt"
msgstr "Als .txt herunterladen"

#: templates/two-factor-onboarding.php:456
msgid "Print"
msgstr "Drucken"

#: templates/two-factor-onboarding.php:463
msgid "I have stored my recovery codes safely."
msgstr "Ich habe meine Wiederherstellungscodes sicher aufbewahrt."

#: templates/two-factor-onboarding.php:466
msgid "Finish"
msgstr "Abschließen"

#: templates/two-factor-onboarding.php:492
msgid "Done — your account is now doubly secure"
msgstr "Fertig — Ihr Konto ist jetzt doppelt abgesichert"

#: templates/two-factor-onboarding.php:494
msgid "You will be asked for the second factor on your next sign-in."
msgstr "Bei Ihrer nächsten Anmeldung werden Sie nach dem zweiten Faktor gefragt."

#. translators: 1: opening link tag, 2: closing link tag
#: templates/two-factor-onboarding.php:508
#, php-format
msgid "This page is protected by %1$sReportedIP%2$s — Open Threat Intelligence for a Safer Internet."
msgstr "Diese Seite wird geschützt durch %1$sReportedIP%2$s — Open Threat Intelligence für ein sichereres Internet."
