msgstr "Google Authenticator, Authy, 1Password — Standard, offline."

#: admin/class-setup-wizard.php:1162
msgid "Passkey / WebAuthn"
msgstr "Passkey / WebAuthn"

#: admin/class-setup-wizard.php:1163
