msgstr "14 Tagen"

#: admin/class-setup-wizard.php:1369
msgid "30 days"
msgstr "30 Tagen"

#: admin/class-setup-wizard.php:1370
msgid "90 days"
msgstr "90 Tagen"

#: admin/class-setup-wizard.php:1375
msgid "Anonymise personal data after"
