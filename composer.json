{
    "name": "reportedip/reportedip-hive",
    "description": "Community-powered WordPress security plugin — real-time threat intelligence with 5-layer defense and 4-method 2FA. Part of the ReportedIP.de ecosystem.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Patrick Schlesinger",
            "email": "1@reportedip.de"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "yahnis-elsts/plugin-update-checker": "^5.6"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpro/grumphp": "^2.5",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.6",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-cli/i18n-command": "^2.6",
        "wp-cli/wp-cli": "^2.10",
        "wp-coding-standards/wpcs": "^3.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "ReportedIP\\Hive\\Tests\\Unit\\": "tests/Unit/",
            "ReportedIP\\Hive\\Tests\\Integration\\": "tests/Integration/",
            "ReportedIP\\Hive\\Tests\\Multisite\\": "tests/Multisite/"
        },
        "classmap": [
            "tests/TestCase.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpro/grumphp": true
        },
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.1"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:multisite": "phpunit -c phpunit-multisite.xml",
        "test:integration": "phpunit --testsuite integration",
        "test:coverage": "phpunit --coverage-html coverage",
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "analyse": "phpstan analyse",
        "analyse:baseline": "phpstan analyse --generate-baseline",
        "make-pot": "wp i18n make-pot . languages/reportedip-hive.pot --slug=reportedip-hive --domain=reportedip-hive --exclude=vendor,tests,bin,build,node_modules",
        "i18n:pot": "@make-pot",
        "i18n:update": [
            "@i18n:pot",
            "wp i18n update-po languages/reportedip-hive.pot languages/reportedip-hive-de_DE.po"
        ],
        "i18n:build": [
            "wp i18n make-mo languages/ languages/",
            "wp i18n make-json languages/ languages/"
        ],
        "i18n": [
            "@i18n:update",
            "@i18n:build"
        ],
        "i18n:check": "@php bin/i18n-check.php",
        "check-all": [
            "@lint",
            "@analyse",
            "@i18n:check",
            "@test:unit"
        ],
        "grumphp": "grumphp run",
        "post-install-cmd": [
            "vendor/bin/grumphp git:init || true"
        ],
        "post-update-cmd": [
            "vendor/bin/grumphp git:init || true"
        ]
    },
    "scripts-descriptions": {
        "test": "Run all PHPUnit tests",
        "test:unit": "Run unit tests only",
        "test:integration": "Run integration tests only",
        "test:coverage": "Run tests with code coverage report",
        "lint": "Check code against WordPress coding standards",
        "lint:fix": "Auto-fix coding standards violations where possible",
        "analyse": "Run PHPStan static analysis",
        "analyse:baseline": "Generate PHPStan baseline for existing issues",
        "make-pot": "Extract translatable strings into languages/reportedip-hive.pot",
        "i18n:pot": "Regenerate the POT template (alias of make-pot)",
        "i18n:update": "Regenerate POT and merge new/changed strings into the German PO (msgmerge)",
        "i18n:build": "Compile every PO into MO plus per-handle JS JSON files",
        "i18n": "Full translation refresh: update PO from source, then compile MO/JSON",
        "i18n:check": "Fail if the POT is stale, the German PO has untranslated/fuzzy entries, or MO/JSON are out of sync",
        "check-all": "Run all quality checks (lint, analyse, i18n:check, test)",
        "grumphp": "Run GrumPHP checks manually"
    }
}
