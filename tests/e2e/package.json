{
  "name": "reportedip-hive-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E suite for ReportedIP Hive — runs against both single-site and multisite Docker stacks.",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:single": "playwright test --project=single-site",
    "test:multisite": "playwright test --project=multisite",
    "ui": "playwright test --ui",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0"
  }
}
